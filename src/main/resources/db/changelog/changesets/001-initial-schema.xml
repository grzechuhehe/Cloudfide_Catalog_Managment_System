<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="001-initial-schema" author="system">
        <createTable tableName="producers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="products">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="producer_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_product_producer" references="producers(id)"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(4000)"/>
            <column name="price" type="DECIMAL(10, 2)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="product_attributes">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_product_attribute_product" references="products(id) on delete cascade"/>
            </column>
            <column name="attribute_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="attribute_value" type="VARCHAR(1000)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Initial Data -->
        <insert tableName="producers">
            <column name="name" value="Samsung"/>
        </insert>
        <insert tableName="producers">
            <column name="name" value="Sony"/>
        </insert>
        <insert tableName="producers">
            <column name="name" value="Apple"/>
        </insert>
    </changeSet>

</databaseChangeLog>
